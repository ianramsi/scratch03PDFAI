# Copy this file to .env and fill in the real values.
# .env is NEVER committed to git (.gitignore enforces this).
# .env.example is the template — uses placeholders, safe to commit.

# ── Shared API key (sent by Salesforce in X-API-Key header) ───────────
# Generate a strong value:  openssl rand -hex 32
# MUST match the X-API-Key value used by Apex FormFinalizeQueueable.
FINALIZER_API_KEY=replace-with-strong-random-secret

# ── Salesforce OAuth (Client Credentials flow) ────────────────────────
# For a sandbox:  https://test.salesforce.com/services/oauth2/token
# For production: https://login.salesforce.com/services/oauth2/token
SF_TOKEN_URL=https://test.salesforce.com/services/oauth2/token
SF_CLIENT_ID=replace-with-connected-app-consumer-key
SF_CLIENT_SECRET=replace-with-connected-app-consumer-secret

# ── Optional tuning ────────────────────────────────────────────────────
SF_API_VERSION=61.0
SF_TOKEN_REFRESH_BUFFER=60
