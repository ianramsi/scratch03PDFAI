# Copy this file to .env and fill in the real values.
# .env is NEVER committed to git (.gitignore enforces this).
# .env.example is the template — uses placeholders, safe to commit.

# ── Shared API key (sent by Salesforce in X-API-Key header) ───────────
# Generate a strong value:  openssl rand -hex 32
# MUST match the X-API-Key value used by Apex FormFinalizeQueueable.
FINALIZER_API_KEY=replace-with-strong-random-secret

# ── Salesforce OAuth — pick ONE flow ──────────────────────────────────
#
# Option A: client_credentials (default)
#   Connected App must have Client Credentials Flow enabled with a Run As user.
#   Requires SF_CLIENT_SECRET.
#
# Option B: jwt (JWT bearer)
#   Connected App must have "Use digital signatures" enabled with the matching
#   public certificate uploaded. Requires SF_JWT_USERNAME, SF_JWT_AUDIENCE
#   and SF_JWT_PRIVATE_KEY. No client secret is sent.
#
SF_AUTH_TYPE=jwt

# Common (both flows)
SF_TOKEN_URL=https://test.salesforce.com/services/oauth2/token
SF_CLIENT_ID=replace-with-connected-app-consumer-key

# client_credentials only (leave empty if using jwt)
SF_CLIENT_SECRET=

# jwt only (leave empty if using client_credentials)
# SF_JWT_USERNAME is the Salesforce user the JWT is "on behalf of" — must be
#   granted access to the Connected App (the "Run As" user).
SF_JWT_USERNAME=replace-with-integration-username
# SF_JWT_AUDIENCE is the Salesforce login host (no /services path).
SF_JWT_AUDIENCE=https://test.salesforce.com
# SF_JWT_PRIVATE_KEY is the PEM-encoded PKCS#8 RSA private key. Newlines
#   are fine; \n escape sequences are also accepted.
SF_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE-WITH-BASE64\n-----END PRIVATE KEY-----"

# ── Optional tuning ────────────────────────────────────────────────────
SF_API_VERSION=61.0
SF_TOKEN_REFRESH_BUFFER=60
