<?xml version="1.0" encoding="UTF-8"?>
<ExternalCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <authenticationProtocol>Custom</authenticationProtocol>
    <label>n8n Form Credential</label>
    <!--
      Custom auth protocol: we inject a static API key header on every callout.
      The header NAME is fixed here; the header VALUE (the secret) is stored as an
      encrypted authentication parameter on the principal below and referenced via
      a Named Credential header formula. We do NOT put the secret in metadata.
    -->
    <externalCredentialParameters>
        <parameterName>NamedPrincipal</parameterName>
        <parameterType>NamedPrincipal</parameterType>
        <sequenceNumber>1</sequenceNumber>
    </externalCredentialParameters>
    <!--
      Authentication parameter that will HOLD the API key secret.
      After deploy: Setup > Named Credentials > External Credentials >
      n8n Form Credential > Principals > edit > set 'ApiKey' value.
    -->
    <externalCredentialParameters>
        <parameterName>ApiKey</parameterName>
        <parameterType>AuthParameter</parameterType>
        <sequenceNumber>2</sequenceNumber>
    </externalCredentialParameters>
</ExternalCredential>
