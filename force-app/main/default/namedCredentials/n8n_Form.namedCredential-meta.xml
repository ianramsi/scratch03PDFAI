<?xml version="1.0" encoding="UTF-8"?>
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>n8n Form</label>
    <namedCredentialType>SecuredEndpoint</namedCredentialType>
    <!-- Base URL only. Paths come from Custom Metadata so they are tunable
         without editing the credential. Replace with your real n8n host. -->
    <calloutUrl>https://n3n3n.suplo.my.id</calloutUrl>
    <allowMergeFieldsInBody>false</allowMergeFieldsInBody>
    <allowMergeFieldsInHeader>true</allowMergeFieldsInHeader>
    <generateAuthorizationHeader>true</generateAuthorizationHeader>
    <externalCredential>n8n_Form_Cred</externalCredential>
    <!--
      Inject the static API key header on every callout using the encrypted
      auth parameter. Header name assumed 'X-API-Key' (matches your option 1).
      If your n8n expects 'Authorization: Bearer <key>' instead, change the
      header name to Authorization and the value to 'Bearer {!$Credential...}'.
    -->
    <namedCredentialParameters>
        <parameterName>X-API-Key</parameterName>
        <parameterType>HttpHeader</parameterType>
        <certificate xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
        <parameterValue>{!$Credential.n8n_Form_Cred.ApiKey}</parameterValue>
    </namedCredentialParameters>
</NamedCredential>
